<%- include('partials/header', { title: 'Register' }) %>

<div class="auth-layout">
  <div class="auth-left">
    
  </div>
  <div class="auth-right">
    <div class="auth-form-box">
      <h1>Register</h1>
      <form method="POST" action="/auth/register">
        <input type="text"  class="form-input auth-input" name="username" placeholder="Username" required autocomplete="username">
        <input type="email" class="form-input auth-input" name="email" placeholder="Email" required autocomplete="email">
        <input type="password" class="form-input auth-input" name="password" placeholder="Password" required autocomplete="new-password">
        <input type="password" class="form-input auth-input" name="confirm_password" placeholder="Confirm Password" required>
        <button type="submit" class="auth-submit">Register</button>
      </form>
      <div class="auth-footer">
        <span>มีบัญชีแล้ว? <a class="link-underline" href="/login">Login</a></span>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
