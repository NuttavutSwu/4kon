<%- include('partials/header', { title: 'Forgot Password' }) %>

<div class="auth-layout">
  <div class="auth-left">
  </div>
  <div class="auth-right">
    <div class="auth-form-box">
      <h1 style="font-size:2.2rem">Forgot Password?</h1>
      <% if (typeof sent !== 'undefined' && sent) { %>
        <div class="form-success">
          ✅ ส่งลิงก์รีเซ็ตไปที่ <strong><%= email %></strong> แล้ว<br>กรุณาตรวจสอบอีเมลของคุณ
        </div>
        <div class="auth-footer" style="margin-top:1.5rem">
          <a href="/login">← กลับไป Login</a>
        </div>
      <% } else { %>
        <p class="forgot-note">ใส่อีเมลที่คุณใช้สมัครสมาชิก ระบบจะส่งลิงก์รีเซ็ตรหัสผ่านให้คุณ</p>
        <form method="POST" action="/auth/forgot-password">
          <input type="email" class="form-input auth-input" name="email" placeholder="Email" required>
          <button type="submit" class="auth-submit" style="width:100%">ส่งลิงก์รีเซ็ต</button>
        </form>
        <div class="auth-footer">
          <a href="/login">← กลับไป Login</a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
