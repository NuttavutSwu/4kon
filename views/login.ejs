<%- include('partials/header', { title: 'Login' }) %>

<div class="auth-layout">
  <div class="auth-left">

  </div>
  <div class="auth-right">
    <div class="auth-form-box">
      <h1>Login with Gmail</h1>
      <% if (error) { %>
        <div class="form-error"><%= error %></div>
      <% } %>
      <a class="auth-google-btn" href="/auth/google">Login with Google Gmail</a>
      <div class="auth-footer">
        <span>สำหรับผู้ใช้ทั่วไป: เข้าสู่ระบบด้วย Gmail เท่านั้น</span>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
