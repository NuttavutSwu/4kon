<%- include('partials/header', { title: 'Login' }) %>

<div class="auth-layout">
  <div class="auth-left">

  </div>
  <div class="auth-right">
    <div class="auth-form-box">
      <h1>Login</h1>
      <form method="POST" action="/auth/login">
        <input type="hidden" name="redirect" value="<%= typeof redirect !== 'undefined' ? redirect : '/' %>">
        <input type="text" class="form-input auth-input" name="username" placeholder="Username" required autocomplete="username">
        <input type="password" class="form-input auth-input" name="password" placeholder="Password" required autocomplete="current-password">
        <button type="submit" class="auth-submit">Login</button>
      </form>
      <div class="auth-footer">
        <a href="/forgot-password">Forgot Password?</a>
        <span>ยังไม่มีบัญชี? <a class="link-underline" href="/register">Register</a></span>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
