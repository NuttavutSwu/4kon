<%- include('partials/header', { title: product.name }) %>

<div class="detail-page">
  <a class="detail-back" href="/wishlist">← กลับ</a>

  <div class="detail-layout">
    <!-- Image -->
    <div class="detail-img-wrap">
      <% if (product.imgUrl) { %>
        <img src="<%= product.imgUrl %>" alt="<%= product.name %>">
      <% } else { %>
        <span class="detail-emoji"><%= product.platform === 'shopee' ? '🛍️' : product.platform === 'lazada' ? '📦' : '🔗' %></span>
      <% } %>
    </div>

    <!-- Info -->
    <div class="detail-info">
      <span class="platform-badge <%= product.platform %>"><%= product.platform || 'other' %></span>
      <% if (product.isPromo) { %>
        <span class="promo-text">🏷️ PROMOTION</span>
      <% } %>
      <h1 class="detail-name"><%= product.name %></h1>
      <div class="detail-price">฿<%= Number(product.price).toLocaleString() %></div>
      <% if (product.category) { %>
        <span class="detail-category"><%= product.category %></span>
      <% } %>
      <% if (product.description) { %>
        <div class="detail-desc"><%= product.description %></div>
      <% } %>
      <% if (product.link) { %>
        <a class="detail-link" href="<%= product.link %>" target="_blank" rel="noopener">🔗 ดูสินค้าต้นทาง</a>
      <% } %>

      <div class="detail-actions">
        <% if (product.link) { %>
          <button class="btn-buy" onclick="buyClick('<%= product.id %>', '<%= product.link %>')">🛒 ซื้อเลย</button>
        <% } %>
        <% if (currentUser) { %>
          <a class="btn-edit-item" href="/products/edit/<%= product.id %>">✏️ แก้ไข</a>
          <form method="POST" action="/products/delete/<%= product.id %>" style="display:inline" onsubmit="return confirm('ลบสินค้านี้?')">
            <button type="submit" class="btn-delete-item">🗑️ ลบ</button>
          </form>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
function buyClick(id, link) {
  fetch('/product/' + id + '/buy', { method: 'POST', headers: {'Content-Type':'application/json'} });
  window.open(link, '_blank');
}
</script>

<%- include('partials/footer') %>
