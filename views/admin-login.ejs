<%- include('partials/header', { title: 'Admin Login' }) %>

<div class="auth-layout">
  <div class="auth-left"></div>
  <div class="auth-right">
    <div class="auth-form-box">
      <h1>Admin Login</h1>
      <% if (error) { %>
        <div class="form-error"><%= error %></div>
      <% } %>
      <form method="POST" action="/auth/admin-login">
        <input type="text" class="form-input auth-input" name="username" placeholder="Admin Username" required autocomplete="username">
        <input type="password" class="form-input auth-input" name="password" placeholder="Password" required autocomplete="current-password">
        <button type="submit" class="auth-submit">เข้าสู่ระบบ Admin</button>
      </form>
      <div class="auth-footer">
        <span>หน้านี้สำหรับผู้ดูแลระบบเท่านั้น</span>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
