<%- include('partials/header', { title: mode === 'edit' ? 'แก้ไขสินค้า' : 'เพิ่มสินค้า' }) %>

<div class="form-page">
  <a class="detail-back" href="/wishlist">← กลับ</a>
  <h1 class="form-page-title"><%= mode === 'edit' ? '✏️ แก้ไขสินค้า' : '＋ เพิ่มสินค้าใหม่' %></h1>

  <form class="product-form" method="POST" action="/products/<%= mode === 'edit' ? 'edit/' + product.id : 'add' %>">

    <!-- Image preview -->
    <div id="imgPreviewBox" class="img-preview-box">
      <% if (product && product.imgUrl) { %>
        <img id="previewImg" src="<%= product.imgUrl %>" alt="preview">
      <% } else { %>
        <span id="previewEmoji" style="font-size:3rem">🖼️</span>
      <% } %>
    </div>

    <div class="form-group">
      <label class="form-label">URL รูปภาพสินค้า</label>
      <input type="text" class="form-input" name="imgUrl" id="imgUrlInput"
             placeholder="https://..." value="<%= product ? (product.imgUrl || '') : '' %>"
             oninput="previewImage(this.value)">
    </div>

    <div class="form-group">
      <label class="form-label">ชื่อสินค้า *</label>
      <input type="text" class="form-input" name="name" required
             placeholder="ชื่อสินค้า" value="<%= product ? product.name : '' %>">
    </div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">ราคา (บาท) *</label>
        <input type="number" class="form-input" name="price" required min="0"
               placeholder="0" value="<%= product ? product.price : '' %>">
      </div>
      <div class="form-group">
        <label class="form-label">แพลตฟอร์ม</label>
        <select class="form-input" name="platform">
          <option value="other"   <%= (!product || product.platform === 'other')   ? 'selected' : '' %>>อื่นๆ</option>
          <option value="shopee"  <%= (product && product.platform === 'shopee')   ? 'selected' : '' %>>Shopee</option>
          <option value="lazada"  <%= (product && product.platform === 'lazada')   ? 'selected' : '' %>>Lazada</option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">Tags</label>
      <input type="hidden" name="category" id="categoryInput" value="<%= product ? (product.category || '') : '' %>">
      <div class="tag-builder">
        <div class="tag-builder-input-row">
          <input type="text" id="tagInput" class="form-input" placeholder="พิมพ์ tag เช่น แฟชั่น แล้วกด +">
          <button type="button" class="tag-add-btn" onclick="addTag()">+</button>
        </div>
        <datalist id="tagSuggestions">
          <% (tagSuggestions || categories || []).forEach(c => { %>
            <option value="<%= typeof c === 'string' ? c : c.name %>"></option>
          <% }) %>
        </datalist>
        <div id="selectedTags" class="selected-tags"></div>
        <% if (mode === 'edit' && categories && categories.length > 0) { %>
          <div class="saved-categories">
            <div class="form-label">Saved Categories</div>
            <div class="saved-category-list" id="savedCategoryList">
              <% categories.forEach(c => { %>
                <% if (c.derived) { %>
                  <div class="saved-category-chip" data-category-name="<%= c.name %>">
                    <span><%= c.name %></span>
                    <button
                      type="button"
                      class="saved-category-delete"
                      aria-label="Delete <%= c.name %>"
                      onclick="deleteSavedCategory(null, <%- JSON.stringify(c.name) %>, this)"
                    >x</button>
                  </div>
                <% } else { %>
                  <div class="saved-category-chip" data-category-name="<%= c.name %>">
                    <span><%= c.name %></span>
                    <button
                      type="button"
                      class="saved-category-delete"
                      aria-label="Delete <%= c.name %>"
                      onclick="deleteSavedCategory(<%- JSON.stringify(c.id) %>, <%- JSON.stringify(c.name) %>, this)"
                    >x</button>
                  </div>
                <% } %>
              <% }) %>
            </div>
          </div>
        <% } %>
      </div>
    </div>

    <div class="form-group">
      <label class="form-label">ลิงก์สินค้า</label>
      <input type="url" class="form-input" name="link"
             placeholder="https://shopee.co.th/..."
             value="<%= product ? (product.link || '') : '' %>">
    </div>

    <div class="form-group">
      <label class="form-label">รายละเอียด</label>
      <textarea class="form-input textarea" name="description"
                placeholder="รายละเอียดสินค้า..."><%= product ? (product.description || '') : '' %></textarea>
    </div>

    <div class="form-check">
      <input type="checkbox" id="isPromo" name="isPromo"
             <%= (product && product.isPromo) ? 'checked' : '' %>>
      <label for="isPromo">สินค้าโปรโมชั่น 🏷️</label>
    </div>

    <div class="form-actions">
      <a class="btn-cancel" href="/wishlist">ยกเลิก</a>
      <button type="submit" class="btn-save">💾 บันทึก</button>
    </div>
  </form>
</div>

<script>
function previewImage(url) {
  const box = document.getElementById('imgPreviewBox');
  if (url) {
    box.innerHTML = '<img id="previewImg" src="' + url + '" alt="preview" onerror="this.parentElement.innerHTML=\'<span style=font-size:3rem>🖼️</span>\'">';
  } else {
    box.innerHTML = '<span style="font-size:3rem">🖼️</span>';
  }
}

const selectedTags = new Set();
const tagInput = document.getElementById('tagInput');
const selectedTagsBox = document.getElementById('selectedTags');
const categoryInput = document.getElementById('categoryInput');
const tagSuggestions = document.getElementById('tagSuggestions');
const savedCategoryList = document.getElementById('savedCategoryList');
const knownCategories = new Set(<%- JSON.stringify((categories || []).map(category => category.name)) %>);
const categoryReturnPath = <%- JSON.stringify(mode === 'edit' && product ? '/products/edit/' + product.id : '/products/add') %>;

tagInput.setAttribute('list', 'tagSuggestions');

function syncTagsToInput() {
  categoryInput.value = Array.from(selectedTags).join(',');
}

function renderTags() {
  if (selectedTags.size === 0) {
    selectedTagsBox.innerHTML = '<span class="tag-empty">ยังไม่มี tag</span>';
    return;
  }
  selectedTagsBox.innerHTML = Array.from(selectedTags).map(tag =>
    '<span class="tag-chip">' + tag +
      '<button type="button" onclick="removeTag(\'' + tag.replace(/'/g, "\\'") + '\')">×</button>' +
    '</span>'
  ).join('');
}

function escapeHtml(value) {
  return String(value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
}

function ensureSuggestionOption(tag) {
  if (!tagSuggestions) return;
  const exists = Array.from(tagSuggestions.options).some(option => option.value === tag);
  if (exists) return;

  const option = document.createElement('option');
  option.value = tag;
  tagSuggestions.appendChild(option);
}

function ensureSavedCategoryChip(category) {
  if (!savedCategoryList || !category || !category.id || category.derived) return;
  const alreadyExists = Array.from(savedCategoryList.querySelectorAll('[data-category-name]'))
    .some((chip) => chip.dataset.categoryName === category.name);
  if (alreadyExists) return;

  const chip = document.createElement('div');
  chip.className = 'saved-category-chip';
  chip.dataset.categoryName = category.name;
  chip.innerHTML = '<span>' + escapeHtml(category.name) + '</span><button type="button" class="saved-category-delete" aria-label="Delete ' + escapeHtml(category.name) + '">x</button>';
  const button = chip.querySelector('button');
  if (button) {
    button.addEventListener('click', () => deleteSavedCategory(category.id, category.name, button));
  }
  savedCategoryList.appendChild(chip);
}

async function deleteSavedCategory(categoryId, categoryName, buttonEl) {
  if (!categoryName) return;
  if (!confirm('Delete this category?')) return;

  try {
    const url = categoryId
      ? ('/categories/delete/' + encodeURIComponent(categoryId))
      : '/categories/delete-name';

    const response = await fetch(url + '?from=' + encodeURIComponent(categoryReturnPath) + '&format=json', {
      method: 'POST',
      headers: {
        'Accept': 'application/json',
        'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
      },
      body: categoryId ? '' : new URLSearchParams({ name: categoryName }).toString()
    });

    if (!response.ok) {
      let payload = {};
      try {
        payload = await response.json();
      } catch (_error) {
        payload = {};
      }
      alert(payload.error || 'Could not delete category right now.');
      return;
    }

    knownCategories.delete(categoryName);
    const chip = buttonEl ? buttonEl.closest('[data-category-name]') : null;
    if (chip) chip.remove();
  } catch (_error) {
    alert('Could not delete category right now.');
  }
}

async function saveCategoryIfNeeded(tag) {
  if (!tag || knownCategories.has(tag)) return;

  const response = await fetch('/categories/add?from=' + encodeURIComponent(categoryReturnPath) + '&format=json', {
    method: 'POST',
    headers: {
      'Accept': 'application/json',
      'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8'
    },
    body: new URLSearchParams({ name: tag }).toString()
  });

  if (!response.ok) {
    throw new Error('Could not save category');
  }

  let payload = {};
  try {
    payload = await response.json();
  } catch (_error) {
    payload = {};
  }

  knownCategories.add(tag);
  ensureSuggestionOption(tag);
  ensureSavedCategoryChip(payload.category || { id: 'temp-' + tag, name: tag });
}

async function addTag() {
  const tag = tagInput.value.trim();
  if (!tag) return;
  try {
    await saveCategoryIfNeeded(tag);
  } catch (_error) {
    alert('Could not save category right now.');
    return;
  }
  selectedTags.add(tag);
  tagInput.value = '';
  syncTagsToInput();
  renderTags();
}

function removeTag(tag) {
  selectedTags.delete(tag);
  syncTagsToInput();
  renderTags();
}

tagInput.addEventListener('keydown', function(event) {
  if (event.key === 'Enter') {
    event.preventDefault();
    addTag();
  }
});

if (categoryInput.value) {
  categoryInput.value.split(',').map(tag => tag.trim()).filter(Boolean).forEach(tag => selectedTags.add(tag));
}
renderTags();
</script>

<%- include('partials/footer') %>
